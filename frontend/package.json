{
  "name": "fitstudio-saas-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "cf-build": "opennextjs-cloudflare build",
    "dev": "next dev --turbopack",
    "start": "next start",
    "lint": "next lint",
    "preview": "npm run cf-build && opennextjs-cloudflare preview",
    "deploy": "npm run cf-build && opennextjs-cloudflare deploy",
    "upload": "npm run cf-build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.78.0"
  }
}