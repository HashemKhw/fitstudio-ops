# Contact form — set at least one path:
# • `next dev`: uses `.env.development` (committed) or `.env.local`; defaults to http://localhost:4000 in dev code.
# • Cloudflare Worker: Dashboard → Variables, or copy vars into `.dev.vars` for `wrangler dev` only.
# • Production Worker: set BACKEND_API_URL (public HTTPS API) or RESEND_API_KEY in the dashboard (not localhost).

BACKEND_API_URL=http://localhost:4000

# Or send without Express: Resend SDK (works on Cloudflare Workers). https://resend.com
# On Cloudflare add RESEND_API_KEY as an encrypted Secret (not a plain “Variable”), or deploy may drop it.
# Create a key in the Resend dashboard, then replace re_xxxxxxxxx with your real API key:
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM=onboarding@resend.dev
# Or with a display name: FitStudio Ops <onboarding@resend.dev>
# CONTACT_TO_EMAIL=hashemkhw1@gmail.com

# Optional: Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Contact CTAs (WhatsApp: digits only, country code, no + or spaces)
NEXT_PUBLIC_WHATSAPP_PHONE=962790013031

NEXT_PUBLIC_CONTACT_EMAIL=hashemkhw1@gmail.com
