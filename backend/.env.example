PORT=4000
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/fitstudio
JWT_SECRET=replace-with-long-random-string
CORS_ORIGIN=http://localhost:3000,https://your-domain.com

# Contact form → email (Gmail: use an App Password, not your normal password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
# Where to receive submissions (defaults to hashemkhw1@gmail.com if unset)
CONTACT_TO_EMAIL=hashemkhw1@gmail.com
# Optional; default is "FitStudio Ops <SMTP_USER>"
# MAIL_FROM=FitStudio Ops <youraddress@gmail.com>

# Optional demo login (replace with real User collection + bcrypt)
DEMO_USER_EMAIL=demo@yourgym.com
DEMO_USER_PASSWORD=change-me-in-production
